# TLS termination + reverse proxy for Obelisk. Caddy fetches and renews a
# Let's Encrypt cert for $OBELISK_DOMAIN automatically and redirects HTTP→HTTPS.
# The app listens plain HTTP on the compose network (app:6060); it is never
# exposed to the host beyond loopback (see docker-compose.yml).

{$OBELISK_DOMAIN} {
	encode zstd gzip

	header {
		# HSTS: force HTTPS for a year, subdomains included.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		# Don't advertise the server software.
		-Server
	}

	# Defense-in-depth body cap (the app also enforces its own limit).
	request_body {
		max_size 2MB
	}

	reverse_proxy app:6060 {
		# flush_interval -1 disables response buffering so the SSE live tail
		# (social.dept.obelisk.subscribeEvents, LAB-45) streams in real time.
		flush_interval -1
	}
}

# Optional: the Obelisk Console (separate stack, obelisk-console). Set CONSOLE_DOMAIN
# to enable — the console container joins this compose's network so Caddy reaches it
# as `console:3000`. Unset → defaults to `localhost` (a harmless no-op vhost).
{$CONSOLE_DOMAIN:localhost} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}

	reverse_proxy console:3000
}
