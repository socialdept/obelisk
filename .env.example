# Postgres (docker compose default)
DATABASE_URL=postgres://obelisk:obelisk@localhost:5432/obelisk

# Tab websocket (docker compose default)
TAB_WS_URL=ws://localhost:2480

# HTTP admin API of the footprint Tab (dynamic /repos mode) that DID-scoped
# archiving enrolls watched DIDs into. Unset until that footprint Tab is running
# (LAB-29) — watched DIDs are still recorded and reconciled once it comes up.
# TAB_FOOTPRINT_ADMIN_URL=http://localhost:2481

# Ollama (host)
OLLAMA_URL=http://127.0.0.1:11434

# HTTP API
PORT=6060

# Public domain for TLS (production overlay only — docker-compose.prod.yml).
# Point this domain's A record at the box before `up`; Caddy auto-issues a
# Let's Encrypt cert for it. Unused for local/plain-HTTP dev.
# OBELISK_DOMAIN=obelisk.example.com

# Set to "true" to disable API authentication entirely. Local development only —
# never enable on anything reachable beyond your machine.
# OBELISK_DEV_MODE=true

# API abuse guards (LAB-52). Shown with their defaults; 0 disables a limit.
# Rate limits are per identity (bearer token, else client IP) per minute.
# OBELISK_RATE_LIMIT_PER_MIN=120
# OBELISK_RATE_LIMIT_EXPENSIVE_PER_MIN=30   # search / aggregate / footprint / feed / network backlinks
# OBELISK_MAX_BODY_BYTES=1048576            # 1 MiB request-body cap (413 over)
# OBELISK_REQUEST_TIMEOUT_MS=30000          # per-request deadline (SSE exempt)
# OBELISK_MAX_SSE_CONNECTIONS=5             # concurrent live tails per identity
# OBELISK_DB_STATEMENT_TIMEOUT_MS=30000     # cancels a slow query at Postgres
