# Postgres. For docker compose, set POSTGRES_PASSWORD (it feeds both the postgres
# container and the app's DATABASE_URL). Generate a strong one for production:
#   openssl rand -hex 32
# The production overlay (docker-compose.prod.yml) REQUIRES this — `up` fails fast
# if it's unset. Local dev falls back to "obelisk" when omitted.
# POSTGRES_PASSWORD=

# Direct DATABASE_URL for running the app on the host (bun run start), outside
# compose. Inside compose the app derives this from POSTGRES_PASSWORD.
DATABASE_URL=postgres://obelisk:obelisk@localhost:5432/obelisk

# Tab websocket (docker compose default)
TAB_WS_URL=ws://localhost:2480

# HTTP admin API of the footprint Tab (dynamic /repos mode) that DID-scoped
# archiving enrolls watched DIDs into. Unset until that footprint Tab is running
# (LAB-29) — watched DIDs are still recorded and reconciled once it comes up.
# TAB_FOOTPRINT_ADMIN_URL=http://localhost:2481

# Which containers docker compose boots. Keep "ollama" for the local embedding
# path; when EMBEDDING_PROVIDER=openai, set this empty (COMPOSE_PROFILES=) so the
# Ollama container never starts and its ~500 MB RAM is freed (LAB-59).
COMPOSE_PROFILES=ollama

# Embedding backend (LAB-9): "ollama" (default, local) or "openai" (API).
# On a small/1-vCPU box, local Ollama saturates the CPU — switch to "openai" to
# offload embeddings (idle CPU, freed RAM, fast parallel throughput, pennies for
# this corpus). Switching providers means re-embedding for coherent vector search
# (see README) — the vector column width stays 768 via the API's dimensions param.
# EMBEDDING_PROVIDER=ollama
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # supports the 768-dim request
# OPENAI_BASE_URL=https://api.openai.com/v1       # any OpenAI-compatible endpoint

# Ollama (host) — used when EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434

# HTTP API
PORT=6060

# Interface the server binds. Default 0.0.0.0 (all interfaces — correct inside a
# container behind the reverse proxy). Set 127.0.0.1 to bind loopback only.
# OBELISK_HOST=0.0.0.0

# Structured-log verbosity: debug | info | warn | error (default info).
# OBELISK_LOG_LEVEL=info

# Public domain for TLS (production overlay only — docker-compose.prod.yml).
# Point this domain's A record at the box before `up`; Caddy auto-issues a
# Let's Encrypt cert for it. Unused for local/plain-HTTP dev.
# OBELISK_DOMAIN=obelisk.example.com

# Set to "true" to disable API authentication entirely. Local development only —
# never enable on anything reachable beyond your machine. Boot REFUSES this when
# the server binds a non-loopback interface unless OBELISK_ALLOW_INSECURE=true.
# OBELISK_DEV_MODE=true
# OBELISK_ALLOW_INSECURE=true   # acknowledge running dev-mode on a public bind

# API abuse guards (LAB-52). Shown with their defaults; 0 disables a limit.
# Rate limits are per identity (bearer token, else client IP) per minute.
# OBELISK_RATE_LIMIT_PER_MIN=120
# OBELISK_RATE_LIMIT_EXPENSIVE_PER_MIN=30   # search / aggregate / footprint / feed / network backlinks
# OBELISK_MAX_BODY_BYTES=1048576            # 1 MiB request-body cap (413 over)
# OBELISK_REQUEST_TIMEOUT_MS=30000          # per-request deadline (SSE exempt)
# OBELISK_MAX_SSE_CONNECTIONS=5             # concurrent live tails per identity
# OBELISK_DB_STATEMENT_TIMEOUT_MS=30000     # cancels a slow query at Postgres
